# --- LOGGING
LOG_LEVEL=INFO
LOG_SENSITIVE=0

# --- API KEY (service-to-service)
PLUMID_API_KEY=change_me_for_internal_calls

# --- AUTH JWT (comptes utilisateurs)
AUTH_SECRET=change_this_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS (CSV d'origines autorisées)
CORS_ALLOW_ORIGINS=*

# --- BASE DE DONNÉES
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=plumid
MYSQL_USER=plumid
MYSQL_PASSWORD=plumid_password

DATABASE_URL=mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@localhost:3306/${MYSQL_DATABASE}?charset=utf8mb4

IP_DB=localhost
PORT_DB=3306
USER_DB=${MYSQL_USER}
MDP_DB=${MYSQL_PASSWORD}
NAME_DB=${MYSQL_DATABASE}
DB_CHARSET=utf8mb4
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
#MYSQL_SSL_CA=/etc/ssl/certs/rds-combined-ca-bundle.pem

# --- SMTP (vérification d'email)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@plumid.local

# --- FRONTEND
FRONTEND_BASE_URL=http://localhost:5173
